{
  "realm": "acme",
  "enabled": true,
  "sslRequired": "none",
  "clients": [
    {
      "clientId": "hivemq-edge",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "test-client-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:*",
        "https://localhost:*"
      ],
      "webOrigins": [
        "*"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-as-roles-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "acme-admin"
      },
      {
        "name": "acme-user"
      }
    ]
  },
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "email": "alice@acme.example",
      "firstName": "Alice",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "alice-password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "acme-admin"
      ],
      "emailVerified": true,
      "requiredActions": []
    },
    {
      "username": "bob",
      "enabled": true,
      "email": "bob@acme.example",
      "firstName": "Bob",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "bob-password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "acme-user"
      ],
      "emailVerified": true,
      "requiredActions": []
    },
    {
      "username": "carol",
      "enabled": true,
      "email": "carol@acme.example",
      "firstName": "Carol",
      "lastName": "Unmapped",
      "credentials": [
        {
          "type": "password",
          "value": "carol-password",
          "temporary": false
        }
      ],
      "realmRoles": [],
      "emailVerified": true,
      "requiredActions": []
    }
  ]
}