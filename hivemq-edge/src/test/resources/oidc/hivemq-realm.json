{
  "realm": "hivemq",
  "enabled": true,
  "sslRequired": "none",
  "clients": [
    {
      "clientId": "hivemq-edge",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "test-client-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:*",
        "https://localhost:*"
      ],
      "webOrigins": [
        "*"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-as-roles-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      { "name": "hivemq-admin" },
      { "name": "hivemq-user" }
    ]
  },
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "email": "alice@example.com",
      "firstName": "Alice",
      "lastName": "Admin",
      "credentials": [
        { "type": "password", "value": "alice-password", "temporary": false }
      ],
      "realmRoles": [ "hivemq-admin" ]
    },
    {
      "username": "bob",
      "enabled": true,
      "email": "bob@example.com",
      "firstName": "Bob",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "bob-password", "temporary": false }
      ],
      "realmRoles": [ "hivemq-user" ]
    },
    {
      "username": "carol",
      "enabled": true,
      "email": "carol@example.com",
      "firstName": "Carol",
      "lastName": "Unmapped",
      "credentials": [
        { "type": "password", "value": "carol-password", "temporary": false }
      ],
      "realmRoles": []
    }
  ]
}
