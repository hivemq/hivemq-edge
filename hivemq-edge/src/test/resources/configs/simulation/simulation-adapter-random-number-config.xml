<hivemq>
    <protocol-adapters>
        <protocol-adapter>
            <adapterId>my-simulation-protocol-adapter</adapterId>
            <protocolId>simulation</protocolId>
            <config>
                <simulationToMqtt>
                    <pollingIntervalMillis>10</pollingIntervalMillis>
                    <maxPollingErrorsBeforeRemoval>9</maxPollingErrorsBeforeRemoval>
                </simulationToMqtt>
            </config>
            <northboundMappings>
                <northboundMapping>
                    <topic>my/topic</topic>
                    <maxQos>1</maxQos>
                    <tagName>random-int</tagName>
                    <messageHandlingOptions>MQTTMessagePerSubscription</messageHandlingOptions>
                    <includeTagNames>true</includeTagNames>
                    <includeTimestamp>false</includeTimestamp>
                </northboundMapping>
            </northboundMappings>
            <tags>
                <tag>
                    <name>random-int</name>
                    <description>random int 0..100</description>
                    <definition>
                        <randomValue>
                            <valueType>INT</valueType>
                            <minValue>0</minValue>
                            <maxValue>100</maxValue>
                        </randomValue>
                    </definition>
                </tag>
                <tag>
                    <name>random-long</name>
                    <description>random long 0..1000000</description>
                    <definition>
                        <randomValue>
                            <valueType>LONG</valueType>
                            <minValue>0</minValue>
                            <maxValue>1000000</maxValue>
                        </randomValue>
                    </definition>
                </tag>
                <tag>
                    <name>random-double</name>
                    <description>random double 0..1</description>
                    <definition>
                        <randomValue>
                            <valueType>DOUBLE</valueType>
                            <minValue>0</minValue>
                            <maxValue>1</maxValue>
                        </randomValue>
                    </definition>
                </tag>
            </tags>
        </protocol-adapter>
    </protocol-adapters>
</hivemq>
